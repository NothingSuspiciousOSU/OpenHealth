# Production environment.
# Configure these in your hosting provider and Convex production deployment.
# Do not commit real production secrets.

# Public Convex URL for the production deployment.
NEXT_PUBLIC_CONVEX_URL=

# Required for AI chat, bill PDF context, and OpenRouter-backed models.
OPENROUTER_API_KEY=

# Optional model overrides. Leave blank to use the app defaults.
PDF_CONTEXT_MODEL=
NEMOTRON_MODEL=

# Required when chat uses web research.
TAVILY_API_KEY=

# Required for AI agent reads against Convex data. This must match the token
# available to Convex functions in production.
AGENT_READ_TOKEN=

# Required for bill document parsing.
NIM_SECRET=
UPLOADTHING_TOKEN=

# Required for /admin data controls. Use a strong unique password.
ADMIN_PAGE_PASSWORD=
