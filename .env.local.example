# Local development environment.
# Copy this file to .env.local, then run `pnpm convex dev`.
# Convex will populate NEXT_PUBLIC_CONVEX_URL and other Convex deployment
# values in .env.local on first setup.

# Required for the app to connect to Convex.
NEXT_PUBLIC_CONVEX_URL=

# Required for AI chat, bill PDF context, and OpenRouter-backed models.
OPENROUTER_API_KEY=

# Optional model overrides. Leave blank to use the app defaults.
PDF_CONTEXT_MODEL=
NEMOTRON_MODEL=

# Required when chat uses web research.
TAVILY_API_KEY=

# Required for AI agent reads against Convex data. Use the same value anywhere
# Convex functions and Next.js server code are deployed.
AGENT_READ_TOKEN=

# Required for bill document parsing.
NIM_SECRET=
UPLOADTHING_TOKEN=

# Required for /admin data controls.
ADMIN_PAGE_PASSWORD=
